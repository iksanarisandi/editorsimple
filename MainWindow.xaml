<Window x:Class="EditorSimple.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:m="clr-namespace:EditorSimple.Models"
        Title="EditorSimple" Height="680" Width="1000" MinHeight="420" MinWidth="640"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13"
        Background="{StaticResource EditorBg}"
        Foreground="{StaticResource FgBrush}"
        PreviewKeyDown="Window_PreviewKeyDown"
        Closing="Window_Closing">
    <Window.Resources>
        <DataTemplate x:Key="TabHeader" DataType="{x:Type m:EditorTab}">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding Header}" VerticalAlignment="Center" Margin="12,0,4,0"/>
                <Button Content="&#xE894;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                        Width="22" Height="22" Padding="0" Margin="2,0,6,0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{StaticResource MutedBrush}"
                        VerticalAlignment="Center" VerticalContentAlignment="Center"
                        Click="CloseTabButton_Click" ToolTip="Close tab (Ctrl+W)"/>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <!-- Menu bar -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_New" InputGestureText="Ctrl+N" Click="New_Click"/>
                <MenuItem Header="_Open File..." InputGestureText="Ctrl+O" Click="OpenFile_Click"/>
                <MenuItem Header="Open _Folder..." InputGestureText="Ctrl+Shift+O" Click="OpenFolder_Click"/>
                <Separator/>
                <MenuItem Header="_Save" InputGestureText="Ctrl+S" Click="Save_Click"/>
                <MenuItem Header="Save _As..." InputGestureText="Ctrl+Shift+S" Click="SaveAs_Click"/>
                <Separator/>
                <MenuItem Header="_Close Tab" InputGestureText="Ctrl+W" Click="CloseTab_Click"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="Toggle _Word Wrap" Click="ToggleWordWrap_Click"/>
            </MenuItem>
        </Menu>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource StatusBg}" Height="24">
            <DockPanel LastChildFill="False">
                <TextBlock x:Name="FormatStatus" Text="No file open" Foreground="White"
                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                <TextBlock x:Name="PositionStatus" Text="" Foreground="White"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
                <TextBlock x:Name="DirtyStatus" Text="" Foreground="White"
                           DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,12,0"/>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="160"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar: file explorer -->
            <DockPanel Grid.Column="0" Background="{StaticResource PanelBg}">
                <DockPanel DockPanel.Dock="Top" Margin="8,8,8,6">
                    <Button DockPanel.Dock="Right" Content="Open Folder" Padding="8,3" Margin="6,0,0,0"
                            Click="OpenFolder_Click"/>
                    <TextBlock Text="EXPLORER" FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
                </DockPanel>
                <Border DockPanel.Dock="Top" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"/>
                <TreeView x:Name="FolderTree" Background="{StaticResource PanelBg}" BorderThickness="0"
                          SelectedItemChanged="FolderTree_SelectedItemChanged"
                          TreeViewItem.Expanded="FolderTree_Expanded"/>
            </DockPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch"
                          Background="{StaticResource BorderBrush}" ResizeBehavior="PreviousAndNext"/>

            <!-- Editor area -->
            <Grid Grid.Column="2">
                <TextBlock x:Name="EmptyHint"
                           Text="Open a file or folder to begin"
                           FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}"/>
                <TabControl x:Name="TabHost"
                            Background="{StaticResource EditorBg}" BorderThickness="0"
                            ItemTemplate="{StaticResource TabHeader}"
                            SelectionChanged="Tabs_SelectionChanged">
                    <TabControl.ContentTemplate>
                        <DataTemplate>
                            <ContentPresenter Content="{Binding Editor}"/>
                        </DataTemplate>
                    </TabControl.ContentTemplate>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
